PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database configuration
DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST/YOUR_DB_NAME?sslmode=require

# Authentication (Minimum 32 characters for JWT_SECRET)
JWT_SECRET=your_super_secret_jwt_key_that_is_at_least_32_chars_long

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stream Chat
STREAM_API_KEY=your_stream_api_key
STREAM_API_SECRET=your_stream_api_secret

# Optional: Google Auth & Email
GOOGLE_CLIENT_ID=your_google_client_id
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# Optional: Stripe (Payments/Webhooks)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: Sentry (Error tracking)
SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.YOUR_REGION.sentry.io/YOUR_PROJECT_ID